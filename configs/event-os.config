# Events OS — Convex + Expo monorepo (pnpm workspaces + turbo).
# Install: ./install.sh --project ~/Documents/Projects/event-os/events-os \
#            --config configs/event-os.config --with-adw

PROJECT_NAME=Events OS
PROJECT_DESCRIPTION=Turns the Public Worship event playbook into software, so any chapter lead in any city can spin up an event, run it, and hand it off.

BRANCH_PREFIX=feature/
COAUTHOR_LINE=Co-Authored-By: Claude <noreply@anthropic.com>

# Monorepo: turbo fans these out to every package that defines the script.
TEST_CMD=pnpm turbo run test
BUILD_CMD=pnpm turbo run build
LINT_CMD=pnpm turbo run lint
TYPECHECK_CMD=pnpm turbo run typecheck

NOTES_PATH=docs/NOTES.md
SPECS_PATH=specs

# Stack line for the Clean Code standard's intro.
PROJECT_STACK=TypeScript / Convex / Expo

# Fresh-worktree dependency install (suggested ADW_WORKTREE_SETUP value).
WORKTREE_SETUP_CMD=pnpm install --prefer-offline
