# Nara Africa — Next.js + Convex, vitest.
# Install: ./install.sh --project ~/Documents/Areas/Nara-Africa/nara-app \
#            --config configs/nara.config --with-adw
#
# NOTE: this repo tracks .claude/ in git, so the harness is committed here rather
# than hidden via .git/info/exclude. Remove the `.claude/` line the installer adds
# to .git/info/exclude after installing, or the new files stay invisible.

PROJECT_NAME=Nara Africa
PROJECT_DESCRIPTION=A US-to-Nigeria shipping and concierge platform: customers submit US retailer URLs, the system scrapes products, prices in USD/NGN, invoices via Zoho Books, and collects payment through Paystack.

BRANCH_PREFIX=feature/
COAUTHOR_LINE=Co-Authored-By: Claude <noreply@anthropic.com>

# `npm test` is bare `vitest`, which is WATCH MODE — it never exits. An agent
# running it as a validation command hangs forever and reads as a crash, so the
# harness uses the run-once forms instead. Do not "simplify" these back.
TEST_CMD=npx vitest run
BUILD_CMD=npm run build
LINT_CMD=npm run lint
TYPECHECK_CMD=npx tsc --noEmit

NOTES_PATH=docs/NOTES.md

# Root-level specs/, deliberately NOT .claude/specs/ — that path belongs to the
# existing spec-create/spec-execute workflow and uses a different
# (requirements/design/tasks triad) format.
SPECS_PATH=specs

# Stack line for the Clean Code standard's intro.
PROJECT_STACK=TypeScript / Next.js / Convex

# Fresh-worktree dependency install (suggested ADW_WORKTREE_SETUP value).
WORKTREE_SETUP_CMD=npm ci
