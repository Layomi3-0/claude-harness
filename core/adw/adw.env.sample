# ADW configuration — copy to adw.env and fill in. Never commit adw.env.
#
# .claude/ is git-excluded by the harness installer, so this file stays local.
# Verify with `git status` after editing.

# ── Authorization ────────────────────────────────────────────────────────────
# Comma-separated GitHub usernames allowed to trigger runs on THIS machine.
# An empty list authorizes NOBODY — that is the intended default. Anyone listed
# here can cause Claude Code to run unsupervised on your computer with your
# credentials, so keep it to people you'd hand your laptop to.
ADW_ALLOWED_AUTHORS=

# Comment body that re-triggers a run on an existing issue.
ADW_TRIGGER_PHRASE=adw

# ── Webhook ──────────────────────────────────────────────────────────────────
# Shared secret proving requests actually came from GitHub. Generate with:
#   openssl rand -hex 32
# Paste the SAME value into the repo's webhook settings. Without it, anyone who
# discovers your tunnel URL can POST to it.
GITHUB_WEBHOOK_SECRET=

# Local port for the webhook server (bound to 127.0.0.1 only; the tunnel reaches it).
ADW_PORT=8001

# Cloudflare tunnel token, used by expose_webhook.sh
CLOUDFLARED_TUNNEL_TOKEN=

# ── Claude Code ──────────────────────────────────────────────────────────────
# LEAVE BLANK to use Claude Code's own login — your claude.ai subscription. That is
# the normal setup and needs no key at all.
#
# Set this ONLY to run as a different identity via the Anthropic API. Note that a
# stale key here (or exported from your shell profile) causes every node to fail with
# a 401 retry loop that looks like a hang. Blank wins over a broken key.
ANTHROPIC_API_KEY=

# If `claude` isn't on PATH for background processes, run `which claude` and paste it.
CLAUDE_CODE_PATH=claude

# Model for pipeline nodes: sonnet (faster, cheaper) or opus (better on hard work).
ADW_MODEL=sonnet

# ── GitHub (optional) ────────────────────────────────────────────────────────
# Only if ADW should act as a different account than your `gh auth login`.
GITHUB_PAT=
