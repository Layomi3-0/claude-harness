# Harness configuration — values substituted into copied harness files.
# Copy/edit this per project, or pass --config <file> to install.sh.
# Format: KEY=value (no quotes needed). Lines starting with # are ignored.

PROJECT_NAME=My Project
PROJECT_DESCRIPTION=A short one-line description of this project.

# Branch prefix enforced by the harness (include the trailing slash).
BRANCH_PREFIX=feature/

# Co-author trailer appended to commits.
COAUTHOR_LINE=Co-Authored-By: Claude <noreply@anthropic.com>

# Project commands (used by /commit, /fix-bug, /clean).
TEST_CMD=npm test
BUILD_CMD=npm run build
LINT_CMD=npm run lint
TYPECHECK_CMD=npx tsc --noEmit

# Where /note writes (absolute path or repo-relative). Default: docs/NOTES.md
NOTES_PATH=docs/NOTES.md
